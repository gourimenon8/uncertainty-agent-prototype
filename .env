# ── Free providers — configure at least one ───────────────────────────────────

# Ollama (local, 100% free — recommended)
# Install: https://ollama.com
# Then run: ollama pull llama3.1 && ollama pull mistral
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434

# Groq (free tier, no credit card — https://console.groq.com)
GROQ_API_KEY=

# Gemini (free tier, no credit card — https://aistudio.google.com)
GEMINI_API_KEY=

CALIBRATION_MONTHS=3